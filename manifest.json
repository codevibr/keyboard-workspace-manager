{
  "manifest_version": 3,
  "name": "Keyboard Workspace Manager",
  "description": "Keyboard-driven pinned-tab workspace manager for Chrome power users.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://calendar.google.com/*",
    "https://messages.google.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "action": {
    "default_title": "Keyboard Workspace Manager"
  },
  "commands": {
    "focus-slot-1": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "windows": "Ctrl+Shift+1"
      },
      "description": "Focus Shortcut 1"
    },
    "focus-slot-2": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "windows": "Ctrl+Shift+2"
      },
      "description": "Focus Shortcut 2"
    },
    "focus-slot-3": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "windows": "Ctrl+Shift+3"
      },
      "description": "Focus Shortcut 3"
    },
    "focus-slot-4": {
      "suggested_key": {
        "default": "Ctrl+Shift+4",
        "windows": "Ctrl+Shift+4"
      },
      "description": "Focus Shortcut 4"
    },
    "focus-slot-5": {
      "description": "Focus Shortcut 5"
    },
    "focus-slot-6": {
      "description": "Focus Shortcut 6"
    },
    "focus-slot-7": {
      "description": "Focus Shortcut 7"
    },
    "focus-slot-8": {
      "description": "Focus Shortcut 8"
    },
    "focus-slot-9": {
      "description": "Focus Shortcut 9"
    },
    "open-chatgpt-panel": {
      "description": "Open or focus ChatGPT floating assistant window"
    }
  }
}
