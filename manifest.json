{
  "manifest_version": 3,
  "name": "Keyboard Workspace Manager",
  "description": "Keyboard shortcuts for configurable pinned tabs and floating browser workspaces.",
  "version": "0.10.2",
  "minimum_chrome_version": "114",
  "permissions": [
    "search",
    "storage",
    "tabs",
    "windows"
  ],
  "optional_permissions": [
    "bookmarks"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "action": {
    "default_title": "Keyboard Workspace Manager",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "19": "icons/icon-19.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png",
      "38": "icons/icon-38.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "focus-slot-01": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "windows": "Ctrl+Shift+1"
      },
      "description": "Focus Shortcut 1"
    },
    "focus-slot-02": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "windows": "Ctrl+Shift+2"
      },
      "description": "Focus Shortcut 2"
    },
    "focus-slot-03": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "windows": "Ctrl+Shift+3"
      },
      "description": "Focus Shortcut 3"
    },
    "focus-slot-04": {
      "suggested_key": {
        "default": "Ctrl+Shift+4",
        "windows": "Ctrl+Shift+4"
      },
      "description": "Focus Shortcut 4"
    },
    "focus-slot-05": {
      "description": "Focus Shortcut 5"
    },
    "focus-slot-06": {
      "description": "Focus Shortcut 6"
    },
    "focus-slot-07": {
      "description": "Focus Shortcut 7"
    },
    "focus-slot-08": {
      "description": "Focus Shortcut 8"
    },
    "focus-slot-09": {
      "description": "Focus Shortcut 9"
    },
    "focus-slot-10": {
      "description": "Focus Shortcut 10"
    },
    "open-command-palette": {
      "description": "Open Command Palette"
    }
  }
}
